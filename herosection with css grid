.hero {
  min-height: 100vh;
  display: grid;
  place-items: center;
}

.hero-content {
  display: grid;
  gap: 2rem;
}

.hero-image img {
  border-radius: 50%;
  width: 250px;
  aspect-ratio: 1;
  object-fit: cover;
  box-shadow: var(--shadow);
}

.hero-text {
  text-align: center;
}

.hero-text h1 {
  font-size: clamp(2rem, 5vw, 4rem);
}

.hero-text p {
  color: var(--text-light);
  margin-top: 1rem;
}