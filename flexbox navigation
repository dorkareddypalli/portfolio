header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255,255,255,.8);
  backdrop-filter: blur(15px);
}

.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 0;
}

.nav-links {
  display: flex;
  gap: 2rem;
  list-style: none;
}

.nav-links a {
  text-decoration: none;
  color: var(--text);
}