.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.contact-form input,
.contact-form textarea {
  padding: 1rem;
  border: none;
  border-radius: 10px;
  background: var(--surface);
  color: var(--text);
}

.btn {
  background: var(--primary);
  color: white;
  padding: 1rem 2rem;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  transition: var(--transition);
}

.btn:hover {
  transform: translateY(-3px);
}